## --- Environment variable --- ##
ENV=LOCAL
DEBUG=false
# TZ=UTC
# PYTHONDONTWRITEBYTECODE=1


## -- API configs -- ##
# Template-level port used by compose port mapping.
ABS_CHALLENGE_API_PORT=10001

# ABS runtime API config consumed by the challenge process.
ABS_API_PORT=10001
# ABS_API_CONFIGS_DIR=/etc/rest-abs-challenge
# ABS_API_LOGS_DIR=/var/log/rest-abs-challenge
# ABS_API_DATA_DIR=/var/lib/rest-abs-challenge
# ABS_API_TMP_DIR=/tmp/rest-abs-challenge
# ABS_API_VERSION=1
# ABS_API_PREFIX=
# ABS_API_DOCS_ENABLED=true
# ABS_API_DOCS_OPENAPI_URL={api_prefix}/openapi.json
# ABS_API_DOCS_DOCS_URL={api_prefix}/docs
# ABS_API_DOCS_REDOC_URL={api_prefix}/redoc

ABS_CHALLENGE_API_KEY=challenge_api_key_here # YOU CAN IGNORE THIS FOR LOCAL TESTING BUT NOT REMOVE
ABS_CHALLENGE_VERIFICATION_API_KEY=verification_api_key_here # YOU CAN IGNORE THIS FOR LOCAL TESTING BUT NOT REMOVE
ABS_CHALLENGE_VERIFICATION_ENDPOINT=http://example.com/
ABS_CHALLENGE_VERIFICATION_STARTUP_URL=http://example.com/

## -- Bot Runner config -- ##
# Use a URL reachable from inside the challenge container.
# For a compose-network bot-runner service, use http://bot-runner:8080.
# For a host/remote bot-runner, use http://<bot-runner-host-ip>:8080.
# ABS_CHALLENGE_BOT_RUNNER__URL=http://bot-runner:8080
# ABS_CHALLENGE_BOT_RUNNER__API_KEY=your_bot_runner_api_key
# Use a URL reachable by the browser running on the bot-runner host.
# Do not use localhost here unless bot-runner runs on the same host as the challenge port mapping.
# ABS_CHALLENGE_BOT_RUNNER__PUBLIC_BASE_URL=http://<challenge-host-ip>:10001
# ABS_CHALLENGE_BOT_RUNNER__DEVICE_TYPE=linux
# ABS_CHALLENGE_BOT_RUNNER__BOT=aad-detect
